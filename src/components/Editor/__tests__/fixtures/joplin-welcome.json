            "items": []
          }
        ],
        "style": "ordered"
      }
    },
    {
      "id": "b6574e9d-0",
      "type": "paragraph",
      "data": {
        "text": "This is a <a href=\"https://joplinapp.org\">link</a> and, finally, below is a horizontal rule:"
      }
    },
    {
      "id": "e30a7d23-e",
      "type": "delimiter",
      "data": {}
    },
    {
      "id": "91262040-9",
      "type": "paragraph",
      "data": {
        "text": "A lot more is possible including adding code samples, math formulae or checkbox lists - see the <a href=\"https://joplinapp.org/help/apps/markdown\">Markdown documentation</a> for more information."
      }
    },
    {
      "id": "f72f8a83-4",
      "type": "header",
      "data": {
        "level": 2,
        "text": "Organising your notes"
      }
    },
    {
      "id": "8ab4bbf9-2",
      "type": "header",
      "data": {
        "level": 3,
        "text": "With notebooks"
      }
    },
    {
      "id": "27f98192-3",
      "type": "paragraph",
      "data": {
        "text": "Joplin notes are organised into a tree of notebooks and sub-notebooks."
      }
    },
    {
      "id": "6ee7cb8c-c",
      "type": "list",
      "data": {
        "items": [
          {
            "content": "On <b>desktop</b>, you can create a notebook by clicking on New Notebook, then you can organise them as you wish by drag and drop them into other notebooks or right-clicking and selecting \"Move to notebook\". You can also drag a sub-notebook to the \"Notebooks\" header to move it to the root.",
            "items": []
          }
        ],
        "style": "unordered"
      }
    },
    {
      "id": "444bb21b-3",
      "type": "list",
      "data": {
        "items": [
          {
            "content": "On <b>mobile</b>, press the \"+\" icon and select \"New notebook\".",
            "items": []
          }
        ],
        "style": "unordered"
      }
    },
    {
      "id": "d294d86c-3",
      "type": "list",
      "data": {
        "items": [
          {
            "content": "On <b>terminal</b>, press <code>:mn</code>",
            "items": []
          }
        ],
        "style": "unordered"
      }
    },
    {
      "id": "51f58c5b-c",
      "type": "image",
      "data": {
        "caption": "",
        "file": {
          "url": "asset://24560359-564f-4407-8e7d-5122f99a7061/adf840e14eef4828a5ca0d712dafadc3.png"
        }
      }
    },
    {
      "id": "9716a85c-b",
      "type": "header",
      "data": {
        "level": 3,
        "text": "With tags"
      }
    },
    {
      "id": "650e931c-a",
      "type": "paragraph",
      "data": {
        "text": "The second way to organise your notes is using tags:"
      }
    },
    {
      "id": "10dbbe73-4",
      "type": "list",
      "data": {
        "items": [
          {
            "content": "On <b>desktop</b>, right-click on any note in the Note List, and select \"Tags\". You can then add the tags, separating them by commas.",
            "items": []
          }
        ],
        "style": "unordered"
      }
    },
    {
      "id": "7e004940-2",
      "type": "list",
      "data": {
        "items": [
          {
            "content": "On <b>mobile</b>, open the note and press the \"\u22ee\" button and select \"Tags\".",
            "items": []
          }
        ],
        "style": "unordered"
      }
    },
    {
      "id": "1a438874-6",
      "type": "list",
      "data": {
        "items": [
          {
            "content": "On <b>terminal</b>, type <code>:help tag</code> for the available commands.",
            "items": []
          }
        ],
        "style": "unordered"
      }
    }
  ]
}